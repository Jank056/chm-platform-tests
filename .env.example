# Copy to .env (gitignored) and fill in real values for local runs.

# CHT environment to test against (staging by default; can override for local dev)
CHT_BASE_URL=https://staging.testapp.communityhealth.media

# MediaHub for cross-system tests
MEDIAHUB_BASE_URL=https://mediahub.communityhealth.media

# Test accounts seeded on the staging environment
PLAYWRIGHT_HCP_EMAIL=playwright-hcp@chmtest.local
PLAYWRIGHT_HCP_PASSWORD=

PLAYWRIGHT_ADMIN_EMAIL=playwright-admin@chmtest.local
PLAYWRIGHT_ADMIN_PASSWORD=

# Optional: a second HCP for state-mutating tests
PLAYWRIGHT_HCP2_EMAIL=playwright-hcp2@chmtest.local
PLAYWRIGHT_HCP2_PASSWORD=
